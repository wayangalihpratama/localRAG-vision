# --- Ollama Configuration ---
# Native Ollama host (use host.docker.internal for Docker-to-Host communication)
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Primary LLM for RAG (Mistral or Llama3 recommended)
OLLAMA_MODEL=mistral

# --- Database Configuration ---
# SQLite for metadata
DATABASE_URL=sqlite:///./localrag.db
# LanceDB path for vector store
VECTOR_DB_PATH=/app/data/lancedb

# --- Redis & Task Queue ---
REDIS_URL=redis://redis:6379/0

# --- S3 / MinIO Configuration ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=raw-documents

# --- Embedding Model ---
# Model used by sentence-transformers
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
